{
  "name": "@padyna/store",
  "version": "0.1.0",
  "description": "High-performance chat state management for Padyna",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "keywords": ["ai", "ai-sdk", "react", "zustand", "state-management", "chat"],
  "license": "MIT",
  "peerDependencies": {
    "@ai-sdk/react": ">=2.0.0",
    "react": ">=18.0.0",
    "zustand": ">=5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "react": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "zustand": "^5.0.8",
    "@ai-sdk/react": "^2.0.71"
  },
  "dependencies": {
    "ai": "^5.0.71"
  }
}
