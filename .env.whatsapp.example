# WhatsApp Business API Integration Environment Variables
# Add these to your .env file

# WhatsApp Business App Configuration
WHATSAPP_APP_ID=your_whatsapp_app_id_here
WHATSAPP_APP_SECRET=your_whatsapp_app_secret_here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here

# Your application URL (for OAuth redirects)
APP_URL=http://localhost:3001

# Example values (replace with your actual values):
# WHATSAPP_APP_ID=123456789012345
# WHATSAPP_APP_SECRET=your_32_character_app_secret
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=my_secure_verify_token_123
# APP_URL=https://yourdomain.com
